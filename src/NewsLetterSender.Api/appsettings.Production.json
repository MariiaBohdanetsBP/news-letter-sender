{
  "ConnectionStrings": {
    "Default": "${CONNECTION_STRING}"
  },
  "Jwt": {
    "Key": "${JWT_SECRET_KEY}"
  },
  "Raynet": {
    "ApiKey": "${RAYNET_API_KEY}",
    "InstanceName": "${RAYNET_INSTANCE_NAME}",
    "BaseUrl": "https://app.raynet.cz/api/v2"
  },
  "Ecomail": {
    "ApiKey": "${ECOMAIL_API_KEY}",
    "BaseUrl": "https://api2.ecomailapp.cz",
    "DefaultListId": "${ECOMAIL_LIST_ID}"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  }
}
